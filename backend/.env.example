# ─────────────────────────────────────────────
# Notely Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env to Git
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/notesDB
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/notesDB
MONGO_URI=mongodb://localhost:27017/notesDB

# JWT secret — use a long, random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_key

# Server port
PORT=3000

# Frontend origin for CORS (e.g. http://localhost:5500 for Live Server)
ALLOWED_ORIGIN=http://localhost:5500
